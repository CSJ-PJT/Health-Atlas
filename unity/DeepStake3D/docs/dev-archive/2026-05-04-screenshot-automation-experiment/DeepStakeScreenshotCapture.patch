+        private static int CountRenderersWithName(string namePart)
+        {
+            var count = 0;
+            var renderers = UnityEngine.Object.FindObjectsByType<Renderer>(FindObjectsInactive.Exclude, FindObjectsSortMode.None);
+            for (var index = 0; index < renderers.Length; index++)
+            {
+                var renderer = renderers[index];
+                if (!IsSceneCaptureRenderer(renderer))
+                {
+                    continue;
+                }
+
+                var transform = renderer.transform;
+                while (transform != null)
+                {
+                    if (transform.name.IndexOf(namePart, StringComparison.OrdinalIgnoreCase) >= 0)
+                    {
+                        count++;
+                        break;
+                    }
+
+                    transform = transform.parent;
+                }
+            }
+
+            return count;
+        }
