+        private static void LogMeshyRegistryState()
+        {
+            if (!File.Exists(MeshyRegistryPath))
+            {
+                Debug.LogWarning("[DeepStakeCapture] Meshy registry not found: " + MeshyRegistryPath);
+                return;
+            }
+
+            try
+            {
+                var registry = JsonUtility.FromJson<MeshyRegistryDocument>(File.ReadAllText(MeshyRegistryPath));
+                var applied = new List<string>();
+                var prefabReady = new List<string>();
+                if (registry?.entries != null)
+                {
+                    for (var index = 0; index < registry.entries.Length; index++)
+                    {
+                        var entry = registry.entries[index];
+                        if (entry == null)
+                        {
+                            continue;
+                        }
+
+                        if (string.Equals(entry.status, "applied", StringComparison.OrdinalIgnoreCase))
+                        {
+                            applied.Add(entry.assetId);
+                        }
+                        else if (string.Equals(entry.status, "prefab_ready", StringComparison.OrdinalIgnoreCase))
+                        {
+                            prefabReady.Add(entry.assetId);
+                        }
+                    }
+                }
+
+                Debug.Log("[DeepStakeCapture] Meshy registry applied=[" + string.Join(", ", applied) +
+                          "] prefab_ready=[" + string.Join(", ", prefabReady) + "]");
+            }
+            catch (Exception exception)
+            {
+                Debug.LogWarning("[DeepStakeCapture] Could not read Meshy registry state. " + exception.Message);
+            }
+        }
