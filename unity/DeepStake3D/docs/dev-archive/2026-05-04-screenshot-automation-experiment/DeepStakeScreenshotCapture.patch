+        private static void FrameOpenEditorCaptureCamera(Camera captureCamera, WorldPrototype3DController controller, MeshySceneState sceneState)
+        {
+            if (captureCamera == null)
+            {
+                return;
+            }
+
+            var serializedController = new SerializedObject(controller);
+            var playerTransform = GetObjectReference<Transform>(serializedController, "playerTransform");
+            var zoneRoot = GetObjectReference<Transform>(serializedController, "zoneRoot");
+            var worldPrototypeJson = GetObjectReference<TextAsset>(serializedController, "worldPrototypeJson");
+
+            var focus = playerTransform != null ? playerTransform.position : Vector3.zero;
+            var requestedOffset = new Vector3(6f, 5f, -6f);
+            if (worldPrototypeJson != null)
+            {
+                try
+                {
+                    var definition = WorldPrototype3DDefinition.FromJson(worldPrototypeJson);
+                    focus = playerTransform != null
+                        ? playerTransform.position
+                        : new Vector3(definition.playerSpawn.x, 0.5f, definition.playerSpawn.z);
+                    requestedOffset = new Vector3(definition.cameraOffset.x, definition.cameraOffset.y, definition.cameraOffset.z);
+                }
+                catch (Exception exception)
+                {
+                    Debug.LogWarning("[DeepStakeCapture] Could not read world prototype camera framing data. " + exception.Message);
+                }
+            }
+
+            if (TryGetRelevantSceneRenderBounds(zoneRoot, playerTransform, sceneState, out var bounds))
+            {
+                focus = bounds.center;
+                var extentMagnitude = Mathf.Max(bounds.extents.magnitude, 4.0f);
+                var planar = new Vector3(requestedOffset.x, 0f, requestedOffset.z);
+                if (planar.sqrMagnitude < 0.01f)
+                {
+                    planar = new Vector3(1f, 0f, -1f);
+                }
+
+                requestedOffset = planar.normalized * Mathf.Clamp(extentMagnitude * 1.65f, 7.0f, 15.0f) +
+                                  Vector3.up * Mathf.Clamp(extentMagnitude * 0.95f, 5.0f, 10.0f);
+            }
+
+            var planarOffset = new Vector3(requestedOffset.x, 0f, requestedOffset.z);
+            if (planarOffset.sqrMagnitude < 0.01f)
+            {
+                planarOffset = new Vector3(1f, 0f, -1f);
+            }
+
+            var distance = Mathf.Clamp(planarOffset.magnitude, 6.5f, 16f);
+            var height = Mathf.Clamp(requestedOffset.y, 5.0f, 10f);
+            var offset = planarOffset.normalized * distance + Vector3.up * height;
+            var lookTarget = focus + Vector3.up * 1.0f;
+
+            captureCamera.transform.position = lookTarget + offset;
+            captureCamera.transform.rotation = Quaternion.LookRotation((lookTarget - captureCamera.transform.position).normalized, Vector3.up);
+            captureCamera.nearClipPlane = 0.1f;
+            captureCamera.farClipPlane = 250f;
+            captureCamera.fieldOfView = Mathf.Clamp(captureCamera.fieldOfView, 49f, 56f);
+            captureCamera.cullingMask = ~0;
+            captureCamera.targetTexture = null;
+        }
+
+        private static bool TryGetRelevantSceneRenderBounds(Transform zoneRoot, Transform playerTransform, MeshySceneState sceneState, out Bounds bounds)
+        {
+            if (sceneState.MeshyRenderers != null && TryGetRendererBounds(sceneState.MeshyRenderers, out bounds))
+            {
+                return true;
+            }
+
+            return TryGetRelevantSceneRenderBounds(zoneRoot, playerTransform, out bounds);
+        }
+
+        private static bool TryGetRelevantSceneRenderBounds(Transform zoneRoot, Transform playerTransform, out Bounds bounds)
+        {
+            var renderers = UnityEngine.Object.FindObjectsByType<Renderer>(FindObjectsInactive.Exclude, FindObjectsSortMode.None);
+            var found = false;
+            bounds = default;
+            var playerPosition = playerTransform != null ? playerTransform.position : Vector3.zero;
+
+            for (var index = 0; index < renderers.Length; index++)
+            {
+                var renderer = renderers[index];
+                if (renderer == null || !renderer.enabled || !renderer.gameObject.activeInHierarchy)
+                {
+                    continue;
+                }
+
+                if (renderer is ParticleSystemRenderer || renderer.GetComponent<Camera>() != null)
+                {
+                    continue;
+                }
+
+                var transform = renderer.transform;
+                var underZone = zoneRoot == null || transform == zoneRoot || transform.IsChildOf(zoneRoot);
+                var nearFirstScreen = Vector3.Distance(renderer.bounds.center, playerPosition) <= 18f;
+                if (!underZone && !nearFirstScreen)
+                {
+                    continue;
+                }
+
+                if (!found)
+                {
+                    bounds = renderer.bounds;
+                    found = true;
+                }
+                else
+                {
+                    bounds.Encapsulate(renderer.bounds);
+                }
+            }
+
+            return found;
+        }
+
+        private static List<Renderer> CollectSceneRenderers(Transform root)
+        {
+            var renderers = root != null
+                ? root.GetComponentsInChildren<Renderer>(includeInactive: false)
+                : UnityEngine.Object.FindObjectsByType<Renderer>(FindObjectsInactive.Exclude, FindObjectsSortMode.None);
+            var collected = new List<Renderer>(renderers.Length);
+            for (var index = 0; index < renderers.Length; index++)
+            {
+                var renderer = renderers[index];
+                if (IsSceneCaptureRenderer(renderer))
+                {
+                    collected.Add(renderer);
+                }
+            }
+
+            return collected;
+        }
+
+        private static bool TryGetRendererBounds(IReadOnlyList<Renderer> renderers, out Bounds bounds)
+        {
+            var found = false;
+            bounds = default;
+            for (var index = 0; index < renderers.Count; index++)
+            {
+                var renderer = renderers[index];
+                if (!IsSceneCaptureRenderer(renderer))
+                {
+                    continue;
+                }
+
+                if (!found)
+                {
+                    bounds = renderer.bounds;
+                    found = true;
+                }
+                else
+                {
+                    bounds.Encapsulate(renderer.bounds);
+                }
+            }
+
+            return found;
+        }
+
+        private static bool IsSceneCaptureRenderer(Renderer renderer)
+        {
+            return renderer != null &&
+                   renderer.enabled &&
+                   renderer.gameObject.activeInHierarchy &&
+                   !(renderer is ParticleSystemRenderer) &&
+                   renderer.GetComponent<Camera>() == null;
+        }
