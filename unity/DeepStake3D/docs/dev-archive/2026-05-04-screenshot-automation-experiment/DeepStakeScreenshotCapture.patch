+        private static bool CameraHasRenderableContent(Camera captureCamera)
+        {
+            if (captureCamera == null)
+            {
+                return false;
+            }
+
+            var planes = GeometryUtility.CalculateFrustumPlanes(captureCamera);
+            var renderers = UnityEngine.Object.FindObjectsByType<Renderer>(FindObjectsInactive.Exclude, FindObjectsSortMode.None);
+            var visibleCount = 0;
+            for (var index = 0; index < renderers.Length; index++)
+            {
+                var renderer = renderers[index];
+                if (renderer == null || !renderer.enabled || !renderer.gameObject.activeInHierarchy)
+                {
+                    continue;
+                }
+
+                if (renderer is ParticleSystemRenderer || renderer.GetComponent<Camera>() != null)
+                {
+                    continue;
+                }
+
+                if (GeometryUtility.TestPlanesAABB(planes, renderer.bounds))
+                {
+                    visibleCount++;
+                    if (visibleCount >= 3)
+                    {
+                        Debug.Log("[DeepStakeCapture] Visible renderer count before capture >= " + visibleCount);
+                        return true;
+                    }
+                }
+            }
+
+            Debug.LogWarning("[DeepStakeCapture] Visible renderer count before capture=" + visibleCount);
+            return visibleCount > 0;
+        }
+
+        private static bool CameraHasMeshyContent(Camera captureCamera, IReadOnlyList<Renderer> meshyRenderers)
+        {
+            if (captureCamera == null || meshyRenderers == null || meshyRenderers.Count == 0)
+            {
+                return false;
+            }
+
+            var planes = GeometryUtility.CalculateFrustumPlanes(captureCamera);
+            var visibleCount = 0;
+            for (var index = 0; index < meshyRenderers.Count; index++)
+            {
+                var renderer = meshyRenderers[index];
+                if (!IsSceneCaptureRenderer(renderer))
+                {
+                    continue;
+                }
+
+                if (GeometryUtility.TestPlanesAABB(planes, renderer.bounds))
+                {
+                    visibleCount++;
+                }
+            }
+
+            Debug.Log("[DeepStakeCapture] Meshy renderer count visible to camera=" + visibleCount + " total=" + meshyRenderers.Count);
+            return visibleCount > 0;
+        }
