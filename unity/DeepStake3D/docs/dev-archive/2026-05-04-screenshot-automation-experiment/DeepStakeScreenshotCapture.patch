+        private static List<string> FindRequiredAppliedMeshyNames(Transform meshyRoot)
+        {
+            var matches = new List<string>();
+            if (meshyRoot == null)
+            {
+                return matches;
+            }
+
+            var children = meshyRoot.GetComponentsInChildren<Transform>(includeInactive: true);
+            for (var requiredIndex = 0; requiredIndex < RequiredAppliedMeshyAssetNames.Length; requiredIndex++)
+            {
+                var requiredName = RequiredAppliedMeshyAssetNames[requiredIndex];
+                for (var childIndex = 0; childIndex < children.Length; childIndex++)
+                {
+                    var child = children[childIndex];
+                    if (child != null && child.name.IndexOf(requiredName, StringComparison.OrdinalIgnoreCase) >= 0)
+                    {
+                        matches.Add(child.name);
+                        break;
+                    }
+                }
+            }
+
+            return matches;
+        }
