+        private static SerializedMeshyCaptureDiagnostics ReadSerializedMeshyCaptureDiagnosticsFallback(string screenshotPath, string failureReason)
+        {
+            var diagnosticsPath = NormalizeOutputPath(SerializedMeshyCaptureDiagnosticsPath);
+            if (!File.Exists(diagnosticsPath))
+            {
+                return new SerializedMeshyCaptureDiagnostics
+                {
+                    Timestamp = DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss"),
+                    CaptureId = string.Empty,
+                    OutputScreenshotPath = screenshotPath,
+                    Success = false,
+                    ResultReason = failureReason
+                };
+            }
+
+            var diagnostics = new SerializedMeshyCaptureDiagnostics
+            {
+                OutputScreenshotPath = screenshotPath,
+                Success = false,
+                ResultReason = failureReason
+            };
+            var lines = File.ReadAllLines(diagnosticsPath);
+            for (var index = 0; index < lines.Length; index++)
+            {
+                var line = lines[index];
+                var separator = line.IndexOf('=');
+                if (separator <= 0)
+                {
+                    continue;
+                }
+
+                var key = line.Substring(0, separator);
+                var value = line.Substring(separator + 1);
+                switch (key)
+                {
+                    case "captureId":
+                        diagnostics.CaptureId = value;
+                        break;
+                    case "timestamp":
+                        diagnostics.Timestamp = value;
+                        break;
+                    case "activeScenePath":
+                        diagnostics.ActiveScenePath = value;
+                        break;
+                    case "meshyVisualDressingFound":
+                        diagnostics.MeshyVisualDressingFound = string.Equals(value, "True", StringComparison.OrdinalIgnoreCase);
+                        break;
+                    case "meshyVisualDressingRendererCount":
+                        int.TryParse(value, out diagnostics.MeshyRendererCount);
+                        break;
+                    case "matchedAppliedAssetObjectNames":
+                        diagnostics.MatchedAppliedAssetObjectNames = SplitDiagnosticList(value);
+                        break;
+                    case "primitiveFallbackDetected":
+                        diagnostics.PrimitiveFallbackDetected = string.Equals(value, "True", StringComparison.OrdinalIgnoreCase);
+                        break;
+                    case "resultReason":
+                        diagnostics.ResultReason = value;
+                        break;
+                }
+            }
+
+            return diagnostics;
+        }
+
+        private static List<string> SplitDiagnosticList(string value)
+        {
+            var result = new List<string>();
+            if (string.IsNullOrWhiteSpace(value))
+            {
+                return result;
+            }
+
+            var parts = value.Split(new[] { ',' }, StringSplitOptions.RemoveEmptyEntries);
+            for (var index = 0; index < parts.Length; index++)
+            {
+                result.Add(parts[index].Trim());
+            }
+
+            return result;
+        }
