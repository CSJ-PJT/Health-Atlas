+        private static MeshySceneState InspectCommittedMeshySceneState(Scene activeScene, WorldPrototype3DController controller)
+        {
+            var meshyRoot = FindSceneGameObject(MeshyVisualDressingRootName);
+            var firstScreenRoot = FindSceneGameObject(FirstScreenVisualDressingRootName);
+            var meshyRenderers = CollectSceneRenderers(meshyRoot != null ? meshyRoot.transform : null);
+            var firstScreenRenderers = CollectSceneRenderers(firstScreenRoot != null ? firstScreenRoot.transform : null);
+            var allRenderers = CollectSceneRenderers(null);
+            var doorRendererCount = CountRenderersWithName("door_wood_old");
+            var windowRendererCount = CountRenderersWithName("window_dark_frame");
+            var noticeRendererCount = CountRenderersWithName("prop_notice_board");
+            var lampRendererCount = CountRenderersWithName("prop_lamp_post");
+
+            Debug.Log(
+                "[DeepStakeCapture] Open editor capture scene state " +
+                "activeScene=" + activeScene.name +
+                " path=" + activeScene.path +
+                " isLoaded=" + activeScene.isLoaded +
+                " controllerExists=" + (controller != null) +
+                " meshyRootExists=" + (meshyRoot != null) +
+                " meshyRendererCount=" + meshyRenderers.Count +
+                " firstScreenRootExists=" + (firstScreenRoot != null) +
+                " firstScreenRendererCount=" + firstScreenRenderers.Count +
+                " sceneRendererCount=" + allRenderers.Count +
+                " door_wood_oldRenderers=" + doorRendererCount +
+                " window_dark_frameRenderers=" + windowRendererCount +
+                " prop_notice_boardRenderers=" + noticeRendererCount +
+                " prop_lamp_postRenderers=" + lampRendererCount);
+
+            if (!string.Equals(activeScene.path, WorldScenePath, StringComparison.OrdinalIgnoreCase))
+            {
+                throw new InvalidOperationException("Wrong active scene for clean capture: " + activeScene.path);
+            }
+
+            if (meshyRoot == null)
+            {
+                throw new InvalidOperationException(
+                    "MeshyVisualDressing missing in active editor scene; open committed WorldPrototype3D scene state or instantiate/apply dressing before capture.");
+            }
+
+            if (meshyRenderers.Count == 0)
+            {
+                throw new InvalidOperationException(
+                    "MeshyVisualDressing exists but has zero visible renderers in active editor scene; refusing primitive fallback capture.");
+            }
+
+            if (TryGetRendererBounds(meshyRenderers, out var meshyBounds))
+            {
+                Debug.Log("[DeepStakeCapture] Meshy target bounds center=" + meshyBounds.center + " size=" + meshyBounds.size);
+            }
+
+            return new MeshySceneState
+            {
+                MeshyRoot = meshyRoot,
+                MeshyRenderers = meshyRenderers,
+                SceneRendererCount = allRenderers.Count
+            };
