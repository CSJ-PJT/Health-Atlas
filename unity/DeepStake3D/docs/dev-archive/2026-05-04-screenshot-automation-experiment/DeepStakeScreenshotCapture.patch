+        private static List<string> FindSceneObjectNamesContaining(string value, int maxCount)
+        {
+            var matches = new List<string>();
+            var allObjects = Resources.FindObjectsOfTypeAll<GameObject>();
+            for (var index = 0; index < allObjects.Length && matches.Count < maxCount; index++)
+            {
+                var candidate = allObjects[index];
+                if (candidate == null || !candidate.scene.IsValid())
+                {
+                    continue;
+                }
+
+                if (!string.Equals(candidate.scene.path, WorldScenePath, StringComparison.OrdinalIgnoreCase))
+                {
+                    continue;
+                }
+
+                if (candidate.name.IndexOf(value, StringComparison.OrdinalIgnoreCase) >= 0)
+                {
+                    matches.Add(candidate.name);
+                }
+            }
+
+            return matches;
+        }
