+        private static bool DetectPrimitiveFallbackObjects(Scene scene, out List<string> primitiveFallbackObjects)
+        {
+            primitiveFallbackObjects = new List<string>();
+            var roots = scene.GetRootGameObjects();
+            for (var rootIndex = 0; rootIndex < roots.Length; rootIndex++)
+            {
+                var root = roots[rootIndex];
+                if (root == null)
+                {
+                    continue;
+                }
+
+                var filters = root.GetComponentsInChildren<MeshFilter>(includeInactive: true);
+                for (var filterIndex = 0; filterIndex < filters.Length; filterIndex++)
+                {
+                    var meshFilter = filters[filterIndex];
+                    if (meshFilter == null || meshFilter.sharedMesh == null)
+                    {
+                        continue;
+                    }
+
+                    var meshName = meshFilter.sharedMesh.name;
+                    if (meshName.IndexOf("Capsule", StringComparison.OrdinalIgnoreCase) >= 0 ||
+                        meshName.IndexOf("Cylinder", StringComparison.OrdinalIgnoreCase) >= 0 ||
+                        meshName.IndexOf("Plane", StringComparison.OrdinalIgnoreCase) >= 0)
+                    {
+                        primitiveFallbackObjects.Add(meshFilter.name + "(" + meshName + ")");
+                    }
+                }
+            }
+
+            return primitiveFallbackObjects.Count > 0;
+        }
