+        private static GameObject CreateSerializedMeshyCaptureCamera(Bounds targetBounds, out Camera captureCamera)
+        {
+            var cameraObject = new GameObject("DeepStakeSerializedMeshyCaptureCamera");
+            cameraObject.hideFlags = HideFlags.HideAndDontSave;
+            captureCamera = cameraObject.AddComponent<Camera>();
+            captureCamera.clearFlags = CameraClearFlags.SolidColor;
+            captureCamera.backgroundColor = new Color(0.66f, 0.71f, 0.72f);
+            captureCamera.fieldOfView = 52f;
+            captureCamera.nearClipPlane = 0.1f;
+            captureCamera.farClipPlane = 300f;
+            captureCamera.cullingMask = ~0;
+
+            var targetCenter = targetBounds.center + Vector3.up * Mathf.Clamp(targetBounds.extents.y * 0.25f, 0.4f, 1.2f);
+            var planarDirection = new Vector3(1f, 0f, -1f).normalized;
+            var extentMagnitude = Mathf.Max(targetBounds.extents.magnitude, 4f);
+            var distance = Mathf.Clamp(extentMagnitude * 1.55f, 8f, 18f);
+            var height = Mathf.Clamp(extentMagnitude * 0.85f, 5.5f, 11f);
+            captureCamera.transform.position = targetCenter + planarDirection * distance + Vector3.up * height;
+            captureCamera.transform.rotation = Quaternion.LookRotation((targetCenter - captureCamera.transform.position).normalized, Vector3.up);
+            return cameraObject;
+        }
